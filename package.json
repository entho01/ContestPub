{
  "name": "contestpub-monorepo",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend --legacy-peer-deps",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run start --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "start:desktop": "electron .",
    "build:desktop": "npm run build:frontend && electron-builder -w"
  },
  "build": {
    "appId": "com.contestpub.app",
    "productName": "ContestPub",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "backend/**/*",
      "frontend/dist/**/*"
    ]
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "wait-on": "^9.0.10"
  }
}
